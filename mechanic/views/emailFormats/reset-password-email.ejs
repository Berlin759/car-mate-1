<%- include("header") %>

    <!-- Greeting Section -->
    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
        <tr>
            <td>
                <h2 style="margin: 0 0 12px 0; color: #1a1a1a; font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 500; line-height: 1.4;">
                    Hello <span style="font-weight: bold;">
                        <%= mechanic_name %>
                    </span>,
                </h2>
                <p style="margin: 0; color: #575757; font-family: 'DM Sans', sans-serif; font-size: 16px; line-height: 1.4;">
                    Your password for the <strong style="color: #575757;">Car Mate</strong>
                    account has been successfully reset. Your account is now secure, and you can
                    log in with your new credentials.
                </p>
            </td>
        </tr>
    </table>

    <!-- Divider -->
    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 28px;">
        <tr>
            <td style="border-bottom: 1px solid #CCCCCC; height: 1px; line-height: 1.4; font-size: 1px;">
                &nbsp;
            </td>
        </tr>
    </table>

    <!-- Reset Details Section -->
    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
        <tr>
            <td>
                <h3 style="margin: 0 0 12px 0; color: #1a1a1a; font-family: 'DM Sans', sans-serif; font-size: 20px; font-weight: bold; line-height: 1.4;">
                    Reset Details
                </h3>

                <!-- Reset Details Table -->
                <table width="100%" cellpadding="0" cellspacing="0">
                    <tr>
                        <td style="padding-bottom: 8px;">
                            <table width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="color: #575757; font-family: 'DM Sans', sans-serif; font-size: 16px;  vertical-align: top;">
                                        Time of Reset :
                                    </td>
                                    <td style="color: #001238; font-family: 'DM Sans', sans-serif; font-size: 16px; text-align: right; vertical-align: top;">
                                        <%= currentTime %>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <table width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="color: #575757; font-family: 'DM Sans', sans-serif; font-size: 16px;  vertical-align: top;">
                                        Device/IP :
                                    </td>
                                    <td style="color: #001238; font-family: 'DM Sans', sans-serif; font-size: 16px; text-align: right; vertical-align: top;">
                                        <%= device %>/XXX.XXX.XXX.XXX
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

<%- include("footer") %>