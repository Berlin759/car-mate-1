<%- include('../header.ejs') %>

<%
    function formatDateFull(date) {
        if (!date) return "-";

        let d = new Date(date);
        let day = ("0" + d.getDate()).slice(-2);
        let month = ("0" + (d.getMonth() + 1)).slice(-2);

        let year = d.getFullYear();
        let hours = ("0" + d.getHours()).slice(-2);
        let minutes = ("0" + d.getMinutes()).slice(-2);

        return `${year}-${month}-${day} ${hours}:${minutes}`;
    };
%>

<div class="d-flex align-items-center justify-content-between mb-30">
    <a href="/mechanic" class="btn btn-outline-secondary d-flex align-items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i> Back to List
    </a>
    <div class="d-flex align-items-center gap-2">
        <label class="text-gray fs-14 mb-0">Status:</label>
        <input type="hidden" id="mechanic-id" value="<%= body?.mechanic?._id %>">
        <select id="mechanic-status-select" class="form-select form-select-sm text-space" style="width: auto;">
            <option value="1" <%= body?.mechanic?.status === 1 ? "selected" : "" %>>Pending</option>
            <option value="2" <%= body?.mechanic?.status === 2 ? "selected" : "" %>>Active</option>
            <option value="4" <%= body?.mechanic?.status === 4 ? "selected" : "" %>>Suspend</option>
        </select>
        <button type="button" id="update-mechanic-status" class="btn btn-primary btn-sm">Update</button>
    </div>
</div>

<div class="row">
    <div class="col-lg-4">
        <div class="bg-white rounded-2 bs-border p-4 mb-30">
            <div class="d-flex flex-column align-items-center text-center">
                <div class="user-avatar-lg text-white mb-3">
                    <% if(body?.mechanic?.profileImage) { %>
                        <img src="<%= body.mechanic.profileImage %>" alt="Profile" class="rounded-circle" width="80" height="80">
                    <% } else { %>
                        <img src="<%= process.env.SERVER_URL + '/images/profile.png' %>" alt="Profile" class="rounded-circle" height="80">
                    <% } %>
                </div>
                <h5 class="mb-1"><%= body?.mechanic?.fullName || "-" %></h5>
                <p class="text-gray mb-0"><%= body?.mechanic?.email || "No email" %></p>
            </div>
            <hr>
            <div class="d-flex flex-column gap-3">
                <div class="d-flex justify-content-between">
                    <span class="text-gray">Phone</span>
                    <span class="fw-md">
                        <% if(body?.mechanic?.phoneNumber) { %>
                            <%= body?.mechanic?.countryCode || "+91" %> <%= body?.mechanic?.phoneNumber %>
                        <% } else { %>
                            -
                        <% } %>
                    </span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-gray">Address</span>
                    <span class="fw-md text-end" style="max-width: 200px;"><%= body?.mechanic?.address || "-" %></span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-gray">Country</span>
                    <span class="fw-md"><%= body?.mechanic?.countryName || "-" %></span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="bg-white rounded-2 bs-border p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e8f5e9; width: 48px; height: 48px;">
                            <i class="fa-solid fa-calendar-check text-success"></i>
                        </div>
                        <div>
                            <span class="fs-14 text-gray d-block">Total Bookings</span>
                            <span class="fs-20 fw-bold"><%= body?.mechanic?.totalBooking || 0 %></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="bg-white rounded-2 bs-border p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e3f2fd; width: 48px; height: 48px;">
                            <i class="fa-solid fa-shield-halved text-primary"></i>
                        </div>
                        <div>
                            <span class="fs-14 text-gray d-block">Email Verified</span>
                            <span class="fs-20 fw-bold"><%= body?.mechanic?.emailVerification === 1 ? "Yes" : "No" %></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="bg-white rounded-2 bs-border p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #fff3e0; width: 48px; height: 48px;">
                            <i class="fa-solid fa-bell text-warning"></i>
                        </div>
                        <div>
                            <span class="fs-14 text-gray d-block">Push Notifications</span>
                            <span class="fs-20 fw-bold"><%= body?.mechanic?.pushNotification === 1 ? "Enabled" : "Disabled" %></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="bg-white rounded-2 bs-border p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #f3e5f5; width: 48px; height: 48px;">
                            <i class="fa-solid fa-wifi text-purple"></i>
                        </div>
                        <div>
                            <span class="fs-14 text-gray d-block">Online Status</span>
                            <span class="fs-20 fw-bold"><%= body?.mechanic?.isOnline === 1 ? "Online" : "Offline" %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2 bs-border p-4 mt-30">
            <h6 class="mb-3">Account Information</h6>
            <hr>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <span class="text-gray fs-14 d-block mb-2">Joined Date</span>
                    <span class="fw-md">
                        <%= formatDateFull(body?.mechanic?.createdAt) || "-" %>
                    </span>
                </div>
                <div class="col-md-6 mb-3">
                    <span class="text-gray fs-14 d-block mb-2">Last Updated</span>
                    <span class="fw-md">
                        <%= formatDateFull(body?.mechanic?.updatedAt) || "-" %>
                    </span>
                </div>
                <div class="col-md-6 mb-3">
                    <span class="text-gray fs-14 d-block mb-2">Last Login</span>
                    <span class="fw-md">
                        <%= body?.mechanic?.lastLoginAt ? formatDateFull(body?.mechanic?.lastLoginAt) : "Never" %>
                    </span>
                </div>
                <div class="col-md-6 mb-3">
                    <span class="text-gray fs-14 d-block mb-2">Description</span>
                    <span class="fw-md"><%= body?.mechanic?.description || "-" %></span>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2 bs-border p-4 mt-30">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="mb-0">KYC Information</h6>
                <div class="d-flex align-items-center gap-2">
                    <% if(!body?.kyc) { %>
                        <a href="/kyc/add/<%= body?.mechanic?._id %>" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                            <i class="fa-solid fa-plus"></i> Submit KYC
                        </a>
                    <% } else { %>
                        <a href="/kyc/<%= body?.mechanic?._id %>" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-1">
                            <i class="fa-solid fa-eye"></i> View KYC Details
                        </a>
                    <% } %>
                </div>
            </div>
            <hr>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <span class="text-gray fs-14 d-block mb-2">KYC Status</span>
                    <span class="fw-md">
                        <% if(body?.kyc?.status === 2) { %>
                            <span class="bet-status alert-success">Approved</span>
                        <% } else if(body?.kyc?.status === 3) { %>
                            <span class="bet-status alert-end">Rejected</span>
                        <% } else if(body?.kyc) { %>
                            <span class="bet-status alert-pending">Pending</span>
                        <% } else { %>
                            <span class="text-gray">Not Submitted</span>
                        <% } %>
                    </span>
                </div>
                <% if(body?.kyc?.status === 3 && body?.kyc?.rejectReason) { %>
                    <div class="col-md-6 mb-3">
                        <span class="text-gray fs-14 d-block mb-2">Rejection Reason</span>
                        <span class="fw-md text-danger"><%= body.kyc.rejectReason %></span>
                    </div>
                <% } %>
                <% if(body?.kyc?.reviewedAt) { %>
                    <div class="col-md-6 mb-3">
                        <span class="text-gray fs-14 d-block mb-2">Reviewed At</span>
                        <span class="fw-md"><%= formatDateFull(body?.kyc?.reviewedAt) %></span>
                    </div>
                <% } %>
                <div class="col-md-6 mb-3">
                    <span class="text-gray fs-14 d-block mb-2">Submitted On</span>
                    <span class="fw-md"><%= body?.kyc ? formatDateFull(body?.kyc?.createdAt) : "-" %></span>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../footer.ejs') %>
