<%- include('../header.ejs') %>

<%
    function formatDateFull(date) {
        if (!date) return "-";
        let d = new Date(date);
        let day = ("0" + d.getDate()).slice(-2);
        let month = ("0" + (d.getMonth() + 1)).slice(-2);
        let year = d.getFullYear();
        let hours = ("0" + d.getHours()).slice(-2);
        let minutes = ("0" + d.getMinutes()).slice(-2);
        return `${year}-${month}-${day} ${hours}:${minutes}`;
    };

    function getTransactionStatusBadge(status) {
        const map = {
            1: { text: "Pending", class: "alert-pending" },
            2: { text: "Paid", class: "alert-success" },
            3: { text: "Failed", class: "alert-end" },
            4: { text: "Refunded", class: "alert-gray" },
        };
        return map[status] || { text: "Unknown", class: "alert-gray" };
    };

    function getBookingStatusBadge(status) {
        const map = {
            1: { text: "Pending", class: "alert-pending" },
            2: { text: "Cancelled", class: "alert-end" },
            3: { text: "Accepted", class: "alert-accept" },
            4: { text: "En Route", class: "alert-accept" },
            5: { text: "Arrived", class: "alert-accept" },
            6: { text: "In Progress", class: "alert-accept" },
            7: { text: "Completed", class: "alert-success" },
            8: { text: "Paid", class: "alert-success" },
            9: { text: "Closed", class: "alert-success" },
        };
        return map[status] || { text: "Unknown", class: "alert-gray" };
    };

    let txn = body?.transaction || {};
    let txnStatus = getTransactionStatusBadge(txn.status);
    let bookStatus = txn.bookingDetails ? getBookingStatusBadge(txn.bookingDetails.status) : null;
%>

<div class="d-flex align-items-center justify-content-between mb-30">
    <a href="/transactions" class="btn btn-outline-secondary d-flex align-items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i> Back to List
    </a>
    <div class="d-flex align-items-center gap-2">
        <span class="bet-status <%= txnStatus.class %>"><%= txnStatus.text %></span>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="bg-white rounded-2 bs-border p-4 mb-30">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e8f5e9; width: 56px; height: 56px;">
                    <i class="fa-solid fa-money-bill-transfer text-success fs-5"></i>
                </div>
                <div>
                    <h5 class="mb-0"><%= txn.invoiceId || "-" %></h5>
                    <span class="text-gray">Transaction ID: <%= txn._id || "-" %></span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e3f2fd; width: 48px; height: 48px;">
                    <i class="fa-solid fa-hashtag text-primary"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">TRX ID</span>
                    <span class="fw-md"><%= txn.trxId || "-" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e8f5e9; width: 48px; height: 48px;">
                    <i class="fa-solid fa-user text-success"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Car Owner</span>
                    <span class="fw-md"><%= txn.ownerDetails?.fullName || "-" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #fff3e0; width: 48px; height: 48px;">
                    <i class="fa-solid fa-wrench text-warning"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Mechanic</span>
                    <span class="fw-md"><%= txn.mechanicDetails?.fullName || "-" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #f3e5f5; width: 48px; height: 48px;">
                    <i class="fa-solid fa-cog text-purple"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Service</span>
                    <span class="fw-md"><%= txn.serviceDetails?.fullName || "-" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e3f2fd; width: 48px; height: 48px;">
                    <i class="fa-solid fa-car text-primary"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Vehicle</span>
                    <span class="fw-md"><%= txn.carDetails?.vehicleNumber || "-" %></span>
                    <span class="text-gray fs-12 d-block"><%= txn.carDetails?.model || "" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e8f5e9; width: 48px; height: 48px;">
                    <i class="fa-solid fa-calendar text-success"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Date</span>
                    <span class="fw-md"><%= formatDateFull(txn.createdAt) || "-" %></span>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (txn.bookingDetails) { %>
<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Booking Reference</h6>
    <hr>
    <div class="row">
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Booking Invoice No</span>
            <span class="fw-md"><%= txn.bookingDetails.invoiceNo || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Booking Date</span>
            <span class="fw-md"><%= formatDateFull(txn.bookingDetails.date) || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Booking Time</span>
            <span class="fw-md"><%= txn.bookingDetails.time || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Booking Status</span>
            <% if (bookStatus) { %>
                <span class="bet-status <%= bookStatus.class %>"><%= bookStatus.text %></span>
            <% } else { %>
                <span class="text-gray">-</span>
            <% } %>
        </div>
    </div>
</div>
<% } %>

<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Payment Details</h6>
    <hr>
    <div class="row">
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Total Amount</span>
            <span class="fw-md fs-16">&#8377; <%= txn.totalAmount || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Admin Charge</span>
            <span class="fw-md">&#8377; <%= txn.adminCharge || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Provider Payout</span>
            <span class="fw-md fs-16 text-success">&#8377; <%= (txn.totalAmount || 0) - (txn.adminCharge || 0) %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Description</span>
            <span class="fw-md"><%= txn.description || "-" %></span>
        </div>
    </div>
</div>

<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Other Details</h6>
    <hr>
    <div class="row">
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Created Date</span>
            <span class="fw-md"><%= formatDateFull(txn.createdAt) || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Last Updated</span>
            <span class="fw-md"><%= formatDateFull(txn.updatedAt) || "-" %></span>
        </div>
    </div>
</div>

<%- include('../footer.ejs') %>
