<%- include('../header.ejs') %>
    <div class="list-filter p-3 bg-white rounded-2 bs-border d-flex align-items-center justify-content-between">
        <div class="filter-area d-flex align-items-center gap-2 flex-wrap" id="service-filter-section">
            <div class="dropdown filter-dropdown">
                <button type="button" class="filter-btn dropdown-toggle" id="status-filter-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="fs-14 fw-md d-flex align-items-center gap-1">
                        <img src="/images/circle-plus.svg" alt="">
                        Service Status
                    </span>
                    <div class="hr-line-sm d-none"></div>
                    <div class="filter-data d-none"></div>
                </button>
                <ul class="dropdown-menu filter-dropdown-menu bs-border bg-white cursor-pointer">
                    <li>
                        <a class="dropdown-item service-status-filter" data-status="1" data-status-text="Active">Active</a>
                    </li>
                    <li>
                        <a class="dropdown-item service-status-filter" data-status="2" data-status-text="InActive">InActive</a>
                    </li>
                    <button id="clear-status-filter" class="clear-btn fs-14 fw-normal text-center w-100 d-none">
                        Clear filters
                    </button>
                </ul>
            </div>
            <div class="dropdown filter-dropdown">
                <button type="button" class="filter-btn dropdown-toggle" id="mechanic-filter-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="fs-14 fw-md d-flex align-items-center gap-1">
                        <img src="/images/circle-plus.svg" alt="">
                        Mechanic
                    </span>
                    <div class="hr-line-sm d-none"></div>
                    <div class="filter-data d-none"></div>
                </button>
                <ul class="dropdown-menu filter-dropdown-menu bs-border bg-white cursor-pointer" style="max-height: 300px; overflow-y: auto;">
                    <% if (body?.mechanics && body.mechanics.length > 0) { %>
                        <% body.mechanics.forEach(function(mechanic) { %>
                            <li>
                                <a class="dropdown-item mechanic-filter" data-mechanic-id="<%= mechanic._id %>" data-mechanic-name="<%= mechanic.fullName %>">
                                    <%= mechanic.fullName %>
                                </a>
                            </li>
                        <% }); %>
                    <% } else { %>
                        <li><span class="dropdown-item text-muted">No mechanics found</span></li>
                    <% } %>
                    <button id="clear-mechanic-filter" class="clear-btn fs-14 fw-normal text-center w-100 d-none">
                        Clear filters
                    </button>
                </ul>
            </div>
            <button type="button" id="reset-service-filters" class="d-none f-reset-btn fs-14 fw-md bg-transparent">
                Reset <img src="/images/f-close.svg" alt="">
            </button>
        </div>
        <div class="d-flex align-items-center flex-wrap justify-content-end gap-2">
            <div class="pagination-show d-flex align-items-center" id="pagination-div-service-list-table-data">
                Show
                <select
                    id="recordPerPage-service-list-table-data"
                    class="form-select form-select-sm w-auto"
                    onchange="changeRecordPerPage('/service-list', 'service-list-table-data')"
                >
                    <option selected="">10</option>
                    <option value="20">20</option>
                    <option value="40">40</option>
                    <option value="60">60</option>
                </select>
            </div>
            <div class="page navigation example">
                <ul class="pagination justify-content-end mb-0 gap-0"></ul>
            </div>
        </div>
    </div>
    <div class="admin-table service-list-table mt-30" id="service-list-table-data"></div>

    <div class="container">
        <div id="add_new_service" class="add-list" data-bs-toggle="modal" data-bs-target="#addServiceModal">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g clip-path="url(#clip0_460_20805)">
                    <path d="M20 8.33337V31.6667" stroke="#ffffff" stroke-width="4" stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    <path d="M8.32812 20H31.6615" stroke="#ffffff" stroke-width="4" stroke-linecap="round"
                        stroke-linejoin="round"></path>
                </g>
                <defs>
                    <clipPath id="clip0_460_20805">
                        <rect width="40" height="40" fill="white"></rect>
                    </clipPath>
                </defs>
            </svg>
        </div>
    </div>

    <!-- Add New Service Modal -->
    <div class="modal custom-popup fade" id="addServiceModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="addServiceModalLabel" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <!-- Modal Header -->
                <div class="modal-header justify-content-center mt-3">
                    <h5 class="modal-title" id="addServiceModalLabel">
                        Add Service
                    </h5>
                </div>

                <!-- Modal Body -->
                <div class="modal-body px-4 pb-4">
                    <form>
                        <input type="hidden" id="service_id" name="service_id" value="" />
                        <div class="row g-3">
                            <div class="col-lg-12">
                                <label for="fullName" class="form-label text-dark">Category Name</label>
                                <input class="form-control" type="text" name="fullName" id="service_name" placeholder="Enter Category Name" maxlength="60" pattern="[a-zA-Z\s]+" minlength="3" title="Category name must contain only alphabetic characters and spaces (min 3 characters)">
                                <div class="text-end fs-11 text-muted" id="service_name_counter">0/50</div>
                            </div>
                            <div class="col-lg-12">
                                <label for="description" class="form-label text-dark">Category Description</label>
                                <textarea class="form-control" type="text" name="description" id="service_description" rows="3" placeholder="Enter Category Description" maxlength="250"></textarea>
                                <div class="text-end fs-11 text-muted" id="service_description_counter">0/200</div>
                            </div>
                            
                            <!-- Sub-categories Section -->
                            <div class="col-lg-12 mt-4">
                                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-2">
                                    <h6 class="text-dark mb-0 fw-semibold">Sub-categories</h6>
                                    <button type="button" class="btn btn-sm btn-outline-primary py-1 px-2 fs-12 d-flex align-items-center gap-1" id="add_subcategory_row_btn">
                                        <i class="fa-solid fa-plus"></i> Add Sub-category
                                    </button>
                                </div>
                                <div id="subcategory_list_container" class="d-flex flex-column gap-3">
                                    <!-- Dynamic Sub-category rows will be appended here -->
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="modal-footer border-0 px-4 d-flex justify-content-end">
                    <button type="button" class="btn btn btn-primary btn-transparent" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-primary" id="add_service">
                        Add Service
                    </button>
                    <button type="button" class="btn btn-primary d-none" id="update_service">
                        Update Service
                    </button>
                </div>
            </div>
        </div>
    </div>

<%- include('../footer.ejs') %>