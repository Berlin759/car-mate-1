<div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Description</th>
                <th>Target</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (body?.announcementList && body.announcementList.length > 0) { body.announcementList.forEach(function(item, index) { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td style="white-space: normal; word-wrap: break-word; max-width: 200px;">
                        <strong><%= item.title || "-" %></strong>
                    </td>
                    <td style="white-space: normal; word-wrap: break-word; max-width: 250px;">
                        <%= item.description || "-" %>
                    </td>
                    <td>
                        <span class="">
                            <%= item.targetRole === "all" ? "All" : item.targetRole === "owner" ? "Car Owners" : item.targetRole === "mechanic" ? "Mechanics" : item.targetRole || "All" %>
                        </span>
                    </td>
                    <td>
                        <select class="form-select form-select-sm announcement-status-select text-border text-space" data-announcement-id="<%= item._id %>" style="width: auto;">
                            <option value="true" <%= item.isActive ? "selected" : "" %>>Active</option>
                            <option value="false" <%= !item.isActive ? "selected" : "" %>>Inactive</option>
                        </select>
                    </td>
                    <td class="text-end">
                        <div class="action-btn d-flex flex-wrap gap-2 justify-content-end">
                            <a href="javascript:void(0);" class="delete-announcement text-danger" data-announcement-id="<%= item._id %>" title="Delete">
                                <i class="fa-regular fa-trash-can"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            <% }); } else { %>
                <tr>
                    <td colspan="6" class="text-center">No announcements found</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
