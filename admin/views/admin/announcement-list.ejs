<div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Description</th>
                <th>Target</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (body?.announcementList && body.announcementList.length > 0) { body.announcementList.forEach(function(item, index) { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td><strong><%= item.title || "-" %></strong></td>
                    <td><%= item.description || "-" %></td>
                    <td><span class="badge bg-primary"><%= item.targetRole || "all" %></span></td>
                    <td>
                        <% if (item.isActive) { %>
                            <span class="bet-status alert-success">Active</span>
                        <% } else { %>
                            <span class="bet-status alert-end">Inactive</span>
                        <% } %>
                    </td>
                    <td class="text-end">
                        <div class="action-btn d-flex flex-wrap gap-2 justify-content-end">
                            <a href="javascript:void(0);" class="delete-announcement text-danger" data-announcement-id="<%= item._id %>" title="Delete">
                                <i class="fa-regular fa-trash-can"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            <% }); } else { %>
                <tr>
                    <td colspan="6" class="text-center">No announcements found</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
