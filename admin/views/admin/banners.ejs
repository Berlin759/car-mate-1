<%- include('../header.ejs') %>
    <div class="list-filter p-3 bg-white rounded-2 bs-border d-flex align-items-center justify-content-between">
        <div class="filter-area d-flex align-items-center gap-2 flex-wrap" id="banner-filter-section">
            <!-- No filters for banners -->
        </div>
        <div class="d-flex align-items-center flex-wrap justify-content-end gap-2">
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addBannerModal" id="add_new_banner_btn">
                <i class="fa-solid fa-plus me-1"></i> Add Banner
            </button>
            <div class="pagination-show d-flex align-items-center" id="pagination-div-banner-list-table-data">
                Show
                <select id="recordPerPage-banner-list-table-data" class="form-select form-select-sm w-auto" onchange="changeRecordPerPage('/banner-list', 'banner-list-table-data')">
                    <option selected="">10</option>
                    <option value="20">20</option>
                    <option value="40">40</option>
                </select>
            </div>
            <div class="page navigation example">
                <ul class="pagination justify-content-end mb-0 gap-0"></ul>
            </div>
        </div>
    </div>
    <div class="admin-table banner-list-table mt-30" id="banner-list-table-data"></div>

    <!-- Add Banner Modal -->
    <div class="modal custom-popup fade" id="addBannerModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header justify-content-center mt-3">
                    <h5 class="modal-title">Add Banner</h5>
                </div>
                <div class="modal-body px-4 pb-4">
                    <div class="row g-3">
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Title</label>
                            <input class="form-control" type="text" id="banner_title" placeholder="Enter banner title" maxlength="60" pattern="[a-zA-Z\s]+" title="Title must contain only alphabetic characters and spaces">
                            <div class="text-end fs-11 text-muted" id="banner_title_counter">0/50</div>
                        </div>
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Description</label>
                            <textarea class="form-control" id="banner_description" rows="2" placeholder="Enter description" maxlength="250"></textarea>
                            <div class="text-end fs-11 text-muted" id="banner_desc_counter">0/200</div>
                        </div>
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Link URL</label>
                            <input class="form-control" type="url" id="banner_link" placeholder="https://example.com">
                        </div>
                        <div class="col-lg-6">
                            <label class="form-label text-dark">Sort Order</label>
                            <input class="form-control" type="number" id="banner_sort_order" value="1" min="1">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 d-flex justify-content-end">
                    <button type="button" class="btn btn-primary btn-transparent" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="save_banner">Save Banner</button>
                </div>
            </div>
        </div>
    </div>
<%- include('../footer.ejs') %>
