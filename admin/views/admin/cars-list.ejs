<%
    function formatDate(date) {
        if(!date){
            return "-";
        };

        let d=new Date(date);
        let day=('0' + d.getDate()).slice(-2);
        let month=('0' + (d.getMonth() + 1)).slice(-2);
        let year=d.getFullYear();
        
        return `${year}-${month}-${day}`;
    };
%>

<div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Owner Name</th>
                <th>Vehicle Number</th>
                <th>Model</th>
                <th>Register Number</th>
                <th>Vehicle Manufacturer Name</th>
                <th>Vehicle Colour</th>
                <th>Vehicle Type</th>
                <th>RC Status</th>
                <th>RC Expiry Date</th>
                <th>Vehicle Insurance Company</th>
                <th>Vehicle Insurance Policy No</th>
                <th>Status</th>
                <th>Created Date</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if(body?.carsList !== undefined && body?.carsList?.length > 0) { %>
                <% body.carsList.forEach((item, index) => { %>
                    <% let start_index = (parseInt(body?.payload?.currentPage) - 1) * parseInt(body?.payload?.itemPerPage) + index + 1; %>
                    <tr>
                        <td><%= start_index %></td>
                        <td><%= item?.fullName || "-" %></td>
                        <td><%= item?.vehicleNumber || "-" %></td>
                        <td><%= item?.model || "-" %></td>
                        <td><%= item?.registerNumber || "-" %></td>
                        <td><%= item?.vehicleManufacturerName || "-" %></td>
                        <td><%= item?.vehicleColour || "-" %></td>
                        <td><%= item?.vehicleType || "-" %></td>
                        <td><%= item?.rcStatus || "-" %></td>
                        <td><%= item?.rcExpiryDate || "-" %></td>
                        <td><%= item?.vehicleInsuranceCompanyName || "-" %></td>
                        <td><%= item?.vehicleInsurancePolicyNo || "-" %></td>
                        <td>
                            <% if(item?.status === 1) { %>
                                <span class="bet-status alert-success">Valid</span>
                            <% } else { %>
                                <span class="bet-status alert-end">InValid</span>
                            <% } %>
                        </td>
                        <td><%= formatDate(item?.createdAt) || "-" %></td>
                        <td class="text-center">
                            <div class="action-btn d-flex justify-content-center">
                                <a href="/cars/<%= item?._id %>" class="car_details_show">
                                    <i class="fa-regular fa-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="8" class="text-center">No cars found</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>