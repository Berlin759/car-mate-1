<div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Description</th>
                <th>Link</th>
                <th>Status</th>
                <th>Order</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (body?.bannerList && body.bannerList.length > 0) { body.bannerList.forEach(function(banner, index) { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td style="white-space: normal; word-wrap: break-word; max-width: 200px;"><strong><%= banner.title || "-" %></strong></td>
                    <td style="white-space: normal; word-wrap: break-word; max-width: 250px;"><%= banner.description || "-" %></td>
                    <td><%= banner.link || "-" %></td>
                    <td>
                        <% if (banner.isActive) { %>
                            <span class="bet-status alert-success">Active</span>
                        <% } else { %>
                            <span class="bet-status alert-end">Inactive</span>
                        <% } %>
                    </td>
                    <td><%= banner.sortOrder || 0 %></td>
                    <td class="text-end">
                        <div class="action-btn d-flex flex-wrap gap-2 justify-content-end">
                            <a href="javascript:void(0);" class="delete-banner text-danger" data-banner-id="<%= banner._id %>" title="Delete">
                                <i class="fa-regular fa-trash-can"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            <% }); } else { %>
                <tr>
                    <td colspan="7" class="text-center">No banners found</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
