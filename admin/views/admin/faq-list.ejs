<div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Question</th>
                <th>Answer</th>
                <th>Category</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (body?.faqList && body.faqList.length > 0) { body.faqList.forEach(function(faq, index) { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td style="white-space: normal; word-wrap: break-word; max-width: 250px;"><strong><%= faq.question || "-" %></strong></td>
                    <td style="white-space: normal; word-wrap: break-word; max-width: 250px;"><%= faq.answer || "-" %></td>
                    <td><%= faq.category || "-" %></td>
                    <td>
                        <select class="form-select form-select-sm faq-status-select text-border text-space" data-faq-id="<%= faq._id %>" style="width: auto;">
                            <option value="true" <%= faq.isActive ? "selected" : "" %>>Active</option>
                            <option value="false" <%= !faq.isActive ? "selected" : "" %>>Inactive</option>
                        </select>
                    </td>
                    <td class="text-end">
                        <div class="action-btn d-flex flex-wrap gap-2 justify-content-end">
                            <a href="javascript:void(0);" class="delete-faq text-danger" data-faq-id="<%= faq._id %>" title="Delete">
                                <i class="fa-regular fa-trash-can"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            <% }); } else { %>
                <tr>
                    <td colspan="6" class="text-center">No FAQs found</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
