<%- include('../header.ejs') %>
    <div class="list-filter p-3 bg-white rounded-2 bs-border d-flex align-items-center justify-content-between">
        <div class="filter-area d-flex align-items-center gap-2 flex-wrap" id="faq-filter-section">
            <!-- No filters for FAQs -->
        </div>
        <div class="d-flex align-items-center flex-wrap justify-content-end gap-2">
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addFaqModal" id="add_new_faq_btn">
                <i class="fa-solid fa-plus me-1"></i> Add FAQ
            </button>
            <div class="pagination-show d-flex align-items-center" id="pagination-div-faq-list-table-data">
                Show
                <select id="recordPerPage-faq-list-table-data" class="form-select form-select-sm w-auto" onchange="changeRecordPerPage('/faq-list', 'faq-list-table-data')">
                    <option selected="">10</option>
                    <option value="20">20</option>
                    <option value="40">40</option>
                </select>
            </div>
            <div class="page navigation example">
                <ul class="pagination justify-content-end mb-0 gap-0"></ul>
            </div>
        </div>
    </div>
    <div class="admin-table faq-list-table mt-30" id="faq-list-table-data"></div>

    <!-- Add FAQ Modal -->
    <div class="modal custom-popup fade" id="addFaqModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header justify-content-center mt-3">
                    <h5 class="modal-title">Add FAQ</h5>
                </div>
                <div class="modal-body px-4 pb-4">
                    <div class="row g-3">
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Question</label>
                            <input class="form-control" type="text" id="faq_question" placeholder="Enter question">
                        </div>
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Answer</label>
                            <textarea class="form-control" id="faq_answer" rows="3" placeholder="Enter answer"></textarea>
                        </div>
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Category <span class="text-danger">*</span></label>
                            <input class="form-control" type="text" id="faq_category" placeholder="e.g. Payment, Booking, General" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 d-flex justify-content-end">
                    <button type="button" class="btn btn-primary btn-transparent" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="save_faq">Save FAQ</button>
                </div>
            </div>
        </div>
    </div>
<%- include('../footer.ejs') %>
