<%- include('../header.ejs') %>
    <div class="list-filter p-3 bg-white rounded-2 bs-border d-flex align-items-center justify-content-between">
        <div class="filter-area d-flex align-items-center gap-2 flex-wrap" id="kyc-filter-section">
            <div class="dropdown filter-dropdown">
                <button type="button" class="filter-btn dropdown-toggle" id="status-filter-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="fs-14 fw-md d-flex align-items-center gap-1">
                        <img src="/images/circle-plus.svg" alt="">
                        KYC Status
                    </span>
                    <div class="hr-line-sm d-none"></div>
                    <div class="filter-data d-none"></div>
                </button>
                <ul class="dropdown-menu filter-dropdown-menu bs-border bg-white cursor-pointer">
                    <li><a class="dropdown-item kyc-status-filter" data-status="1" data-status-text="Pending">Pending</a></li>
                    <li><a class="dropdown-item kyc-status-filter" data-status="2" data-status-text="Approved">Approved</a></li>
                    <li><a class="dropdown-item kyc-status-filter" data-status="3" data-status-text="Rejected">Rejected</a></li>
                    <button id="clear-status-filter" class="clear-btn fs-14 fw-normal text-center w-100 d-none">Clear filters</button>
                </ul>
            </div>
            <button type="button" id="reset-kyc-filters" class="d-none f-reset-btn fs-14 fw-md bg-transparent">
                Reset <img src="/images/f-close.svg" alt="">
            </button>
        </div>
        <div class="d-flex align-items-center flex-wrap justify-content-end gap-2">
            <div class="pagination-show d-flex align-items-center" id="pagination-div-kyc-list-table-data">
                Show
                <select id="recordPerPage-kyc-list-table-data" class="form-select form-select-sm w-auto" onchange="changeRecordPerPage('/kyc-list', 'kyc-list-table-data')">
                    <option selected="">10</option>
                    <option value="20">20</option>
                    <option value="40">40</option>
                </select>
            </div>
            <div class="page navigation example">
                <ul class="pagination justify-content-end mb-0 gap-0"></ul>
            </div>
        </div>
    </div>
    <div class="admin-table kyc-list-table mt-30" id="kyc-list-table-data"></div>

    <!-- KYC Details Modal -->
    <div class="modal custom-popup fade" id="kycDetailModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header justify-content-center mt-3">
                    <h5 class="modal-title">KYC Details</h5>
                </div>
                <div class="modal-body px-4 pb-4" id="kyc-details-body">
                    <div class="info-grid d-flex flex-wrap">
                        <div class="in-grd-item"><p class="mb-1 text-gray">Mechanic</p><div class="value" id="kyc-mechanic-name">-</div></div>
                        <div class="in-grd-item"><p class="mb-1 text-gray">Document Type</p><div class="value" id="kyc-doc-type">-</div></div>
                        <div class="in-grd-item"><p class="mb-1 text-gray">Status</p><div class="value" id="kyc-status">-</div></div>
                        <div class="in-grd-item"><p class="mb-1 text-gray">Submitted</p><div class="value" id="kyc-submitted">-</div></div>
                    </div>
                    <div class="divider"></div>
                    <div class="mb-3"><p class="mb-1 text-gray">Document Number</p><div class="value" id="kyc-doc-number">-</div></div>
                    <div class="mb-3"><p class="mb-1 text-gray">Document Image</p><div id="kyc-doc-image"></div></div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-success" id="kyc-approve-btn">Approve</button>
                        <button type="button" class="btn btn-danger" id="kyc-reject-btn">Reject</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
<%- include('../footer.ejs') %>
