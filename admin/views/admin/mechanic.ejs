<%- include('../header.ejs') %>
    <div class="list-filter p-3 bg-white rounded-2 bs-border d-flex align-items-center justify-content-between">
        <div class="filter-area" id="mechanic-filter-section">
            <div class="dropdown filter-dropdown">
                <button type="button" class="filter-btn dropdown-toggle" id="email-filter-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="fs-14 fw-md d-flex align-items-center gap-1">
                        <img src="/images/circle-plus.svg" alt="">
                        Email
                    </span>
                    <div class="hr-line-sm d-none"></div>
                    <div class="filter-data d-none"></div>
                </button>
                <ul class="dropdown-menu filter-dropdown-menu amount-filter bs-border bg-white">
                    <span class="fw-md fs-14 text-start">Filter by Email</span>
                    <div class="form-group mt-10">
                        <input id="email-filter-input" class="form-control" type="text" name="email" placeholder="Enter Email">
                    </div>
                    <button id="apply-email-filter" class="btn btn-primary w-100 d-block mt-10 btn-disabled">Apply</button>
                    <!-- <div class="cl-btn-wrapper">
                        <button class="clear-btn fs-14 fw-normal text-center w-100">Clear filters</button>
                    </div> -->
                    <button id="clear-email-filter" class="clear-btn fs-14 fw-normal text-center w-100 d-none">
                        Clear filters
                    </button>
                </ul>
            </div>
            <div class="dropdown filter-dropdown">
                <button type="button" class="filter-btn dropdown-toggle" id="status-filter-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="fs-14 fw-md d-flex align-items-center gap-1">
                        <img src="/images/circle-plus.svg" alt="">
                        Mechanic Status
                    </span>
                    <div class="hr-line-sm d-none"></div>
                    <div class="filter-data d-none"></div>
                </button>
                <ul class="dropdown-menu filter-dropdown-menu bs-border bg-white cursor-pointer">
                    <li>
                        <a class="dropdown-item mechanic-status-filter" data-status="1" data-status-text="Pending">Pending</a>
                    </li>
                    <li>
                        <a class="dropdown-item mechanic-status-filter" data-status="2" data-status-text="Active">Active</a>
                    </li>
                    <li>
                        <a class="dropdown-item mechanic-status-filter" data-status="3" data-status-text="Inactive">In Active</a>
                    </li>
                    <li>
                        <a class="dropdown-item mechanic-status-filter" data-status="4" data-status-text="Suspended">Suspended</a>
                    </li>
                    <!-- <div class="cl-btn-wrapper">
                        <button class="clear-btn fs-14 fw-normal text-center w-100">Clear filters</button>
                    </div> -->
                    <button id="clear-status-filter" class="clear-btn fs-14 fw-normal text-center w-100 d-none">
                        Clear filters
                    </button>
                </ul>
            </div>
            <div class="dropdown filter-dropdown">
                <button type="button" class="filter-btn dropdown-toggle" id="kyc-status-filter-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="fs-14 fw-md d-flex align-items-center gap-1">
                        <img src="/images/circle-plus.svg" alt="">
                        KYC Status
                    </span>
                    <div class="hr-line-sm d-none"></div>
                    <div class="filter-data d-none"></div>
                </button>
                <ul class="dropdown-menu filter-dropdown-menu bs-border bg-white cursor-pointer">
                    <li>
                        <a class="dropdown-item mechanic-kyc-status-filter" data-kyc-status="not_submitted" data-kyc-status-text="Not Submitted">Not Submitted</a>
                    </li>
                    <li>
                        <a class="dropdown-item mechanic-kyc-status-filter" data-kyc-status="1" data-kyc-status-text="Pending">Pending</a>
                    </li>
                    <li>
                        <a class="dropdown-item mechanic-kyc-status-filter" data-kyc-status="2" data-kyc-status-text="Approved">Approved</a>
                    </li>
                    <li>
                        <a class="dropdown-item mechanic-kyc-status-filter" data-kyc-status="3" data-kyc-status-text="Rejected">Rejected</a>
                    </li>
                    <button id="clear-kyc-status-filter" class="clear-btn fs-14 fw-normal text-center w-100 d-none">
                        Clear filters
                    </button>
                </ul>
            </div>
            <button type="button" id="reset-mechanic-filters" class="d-none f-reset-btn fs-14 fw-md bg-transparent">
                Reset <img src="/images/f-close.svg" alt="">
            </button>
        </div>
        <div class="d-flex align-items-center flex-wrap justify-content-end gap-2">
            <div class="pagination-show d-flex align-items-center" id="pagination-div-mechanic-list-table-data">
                Show
                <select
                    id="recordPerPage-mechanic-list-table-data"
                    class="form-select form-select-sm w-auto"
                    onchange="changeRecordPerPage('/mechanic-list', 'mechanic-list-table-data')"
                >
                    <option selected="">10</option>
                    <option value="20">20</option>
                    <option value="40">40</option>
                    <option value="60">60</option>
                </select>
            </div>
            <div class="page navigation example">
                <ul class="pagination justify-content-end mb-0 gap-0"></ul>
            </div>
        </div>
    </div>
    <div class="admin-table mechanic-list-table mt-30" id="mechanic-list-table-data"></div>

    <div class="container">
        <div id="add_new_mechanic" class="add-list" data-bs-toggle="modal" data-bs-target="#addMechanicModal">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g clip-path="url(#clip0_460_20805)">
                    <path d="M20 8.33337V31.6667" stroke="#ffffff" stroke-width="4" stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    <path d="M8.32812 20H31.6615" stroke="#ffffff" stroke-width="4" stroke-linecap="round"
                        stroke-linejoin="round"></path>
                </g>
                <defs>
                    <clipPath id="clip0_460_20805">
                        <rect width="40" height="40" fill="white"></rect>
                    </clipPath>
                </defs>
            </svg>
        </div>
    </div>

    <!-- Add New Mechanic Modal -->
    <div class="modal custom-popup fade" id="addMechanicModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="addMechanicModalLabel" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <!-- Modal Header -->
                <div class="modal-header justify-content-center mt-3">
                    <h5 class="modal-title" id="addMechanicModalLabel">
                        Add Mechanic
                    </h5>
                </div>

                <!-- Modal Body -->
                <div class="modal-body px-4 pb-4">
                    <form>
                        <input type="hidden" id="mechanic_id" name="mechanic_id" value="" />
                        <div class="row g-3">
                            <div class="col-lg-12">
                                <label for="full_name" class="form-label text-dark">Enter Mechanic Name</label>
                                <input class="form-control" type="text" name="full_name" id="full_name" placeholder="Enter Mechanic Name" required pattern="[a-zA-Z\s]+" minlength="2" maxlength="50" title="Name must contain only letters and spaces (2-50 characters)">
                            </div>
                            <div class="col-lg-12">
                                <label for="phone_number" class="form-label text-dark">Enter Phone Number</label>
                                <div class="input-group">
                                    <select class="form-select" id="phone_code" name="phone_code" style="max-width: 130px;">
                                        <option value="+1" data-max-length="10">+1 (US)</option>
                                        <option value="+44" data-max-length="10">+44 (UK)</option>
                                        <option value="+91" selected data-max-length="10">+91 (IN)</option>
                                        <option value="+61" data-max-length="9">+61 (AU)</option>
                                        <option value="+86" data-max-length="11">+86 (CN)</option>
                                        <option value="+81" data-max-length="10">+81 (JP)</option>
                                        <option value="+49" data-max-length="11">+49 (DE)</option>
                                        <option value="+33" data-max-length="9">+33 (FR)</option>
                                        <option value="+55" data-max-length="11">+55 (BR)</option>
                                        <option value="+7" data-max-length="10">+7 (RU)</option>
                                        <option value="+82" data-max-length="10">+82 (KR)</option>
                                        <option value="+39" data-max-length="10">+39 (IT)</option>
                                        <option value="+34" data-max-length="9">+34 (ES)</option>
                                        <option value="+31" data-max-length="9">+31 (NL)</option>
                                        <option value="+46" data-max-length="10">+46 (SE)</option>
                                        <option value="+41" data-max-length="9">+41 (CH)</option>
                                        <option value="+971" data-max-length="9">+971 (UAE)</option>
                                        <option value="+966" data-max-length="9">+966 (SA)</option>
                                        <option value="+65" data-max-length="8">+65 (SG)</option>
                                        <option value="+60" data-max-length="10">+60 (MY)</option>
                                        <option value="+63" data-max-length="10">+63 (PH)</option>
                                        <option value="+66" data-max-length="9">+66 (TH)</option>
                                        <option value="+84" data-max-length="10">+84 (VN)</option>
                                        <option value="+92" data-max-length="10">+92 (PK)</option>
                                        <option value="+880" data-max-length="10">+880 (BD)</option>
                                        <option value="+94" data-max-length="9">+94 (LK)</option>
                                        <option value="+977" data-max-length="10">+977 (NP)</option>
                                    </select>
                                    <input class="form-control" type="tel" name="phone_number" id="phone_number" placeholder="Enter Phone Number" inputmode="numeric" maxlength="10">
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="modal-footer border-0 px-4 d-flex justify-content-end">
                    <button type="button" class="btn btn btn-primary btn-transparent" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-primary" id="add_mechanic">
                        Add Mechanic
                    </button>
                    <button type="button" class="btn btn-primary d-none" id="update_mechanic">
                        Update Mechanic
                    </button>
                </div>
            </div>
        </div>
    </div>

<%- include('../footer.ejs') %>