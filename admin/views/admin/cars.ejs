<%- include('../header.ejs') %>
    <div class="list-filter p-3 bg-white rounded-2 bs-border d-flex align-items-center justify-content-between">
        <div class="filter-area" id="car-filter-section">
            <div class="dropdown filter-dropdown">
                <button type="button" class="filter-btn dropdown-toggle" id="status-filter-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="fs-14 fw-md d-flex align-items-center gap-1">
                        <img src="/images/circle-plus.svg" alt="">
                        Car Status
                    </span>
                    <div class="hr-line-sm d-none"></div>
                    <div class="filter-data d-none"></div>
                </button>
                <ul class="dropdown-menu filter-dropdown-menu bs-border bg-white cursor-pointer">
                    <li>
                        <a class="dropdown-item car-status-filter" data-status="1" data-status-text="Valid">Valid</a>
                    </li>
                    <li>
                        <a class="dropdown-item car-status-filter" data-status="2" data-status-text="InValid">InValid</a>
                    </li>
                    <!-- <div class="cl-btn-wrapper">
                        <button class="clear-btn fs-14 fw-normal text-center w-100">Clear filters</button>
                    </div> -->
                    <button id="clear-status-filter" class="clear-btn fs-14 fw-normal text-center w-100 d-none">
                        Clear filters
                    </button>
                </ul>
            </div>
            <button type="button" id="reset-car-filters" class="d-none f-reset-btn fs-14 fw-md bg-transparent">
                Reset <img src="/images/f-close.svg" alt="">
            </button>
        </div>
        <div class="d-flex align-items-center flex-wrap justify-content-end gap-2">
            <div class="pagination-show d-flex align-items-center" id="pagination-div-car-list-table-data">
                Show
                <select
                    id="recordPerPage-car-list-table-data"
                    class="form-select form-select-sm w-auto"
                    onchange="changeRecordPerPage('/car-list', 'car-list-table-data')"
                >
                    <option selected="">10</option>
                    <option value="20">20</option>
                    <option value="40">40</option>
                    <option value="60">60</option>
                </select>
            </div>
            <div class="page navigation example">
                <ul class="pagination justify-content-end mb-0 gap-0"></ul>
            </div>
        </div>
    </div>
    <div class="admin-table car-list-table mt-30" id="car-list-table-data"></div>

    <div class="container">
        <div id="add_new_car" class="add-list" data-bs-toggle="modal" data-bs-target="#addCarModal">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g clip-path="url(#clip0_460_20805)">
                    <path d="M20 8.33337V31.6667" stroke="#ffffff" stroke-width="4" stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    <path d="M8.32812 20H31.6615" stroke="#ffffff" stroke-width="4" stroke-linecap="round"
                        stroke-linejoin="round"></path>
                </g>
                <defs>
                    <clipPath id="clip0_460_20805">
                        <rect width="40" height="40" fill="white"></rect>
                    </clipPath>
                </defs>
            </svg>
        </div>
    </div>

    <!-- Add New Car Modal -->
    <div class="modal custom-popup fade" id="addCarModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="addCarModalLabel" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <!-- Modal Header -->
                <div class="modal-header justify-content-center mt-3">
                    <h5 class="modal-title" id="addCarModalLabel">
                        Add Car
                    </h5>
                </div>

                <!-- Modal Body -->
                <div class="modal-body px-4 pb-4">
                    <form id="addCarForm" enctype="multipart/form-data">
                        <input type="hidden" id="car_id" name="car_id" value="" />
                        <div class="row g-3">
                            <div class="col-lg-12">
                                <label for="vehicle_number" class="form-label text-dark">Enter Vehicle Number</label>
                                <input class="form-control" type="text" name="vehicle_number" id="vehicle_number" placeholder="Enter Vehicle Number">
                            </div>
                            <div class="col-lg-12">
                                <label for="car_images" class="form-label text-dark">Car Images (Max 4)</label>
                                <input class="form-control" type="file" name="images" id="car_images" multiple accept="image/*">
                                <small class="text-muted">You can upload up to 4 images (JPG, PNG, WebP)</small>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Modal Footer -->
                <div class="modal-footer border-0 px-4 d-flex justify-content-end">
                    <button type="button" class="btn btn btn-primary btn-transparent" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-primary" id="add_car">
                        Add Car
                    </button>
                    <button type="button" class="btn btn-primary d-none" id="update_car">
                        Update Car
                    </button>
                </div>
            </div>
        </div>
    </div>

<%- include('../footer.ejs') %>