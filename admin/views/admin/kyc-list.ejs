<%
    function formatDate(date) {
        if(!date){
            return "-";
        };
        let d=new Date(date);
        let day=('0' + d.getDate()).slice(-2);
        let month=('0' + (d.getMonth() + 1)).slice(-2);
        let year=d.getFullYear();
        return `${year}-${month}-${day}`;
    };
%>

<div class="table-responsive">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Mechanic Name</th>
                <th>Document Type</th>
                <th>Document Number</th>
                <th>Status</th>
                <th>Submitted</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if(body?.kycList !== undefined && body?.kycList?.length > 0) { %>
                <% body.kycList.forEach((item, index) => { %>
                    <% let start_index = (parseInt(body?.param?.currentPage) - 1) * parseInt(body?.param?.itemPerPage) + index + 1; %>
                    <tr>
                        <td><%= start_index %></td>
                        <td>
                            <strong><%= item?.mechanicDetails?.[0]?.fullName || "-" %></strong>
                            <div class="text-muted fs-12"><%= item?.mechanicDetails?.[0]?.phoneNumber || "" %></div>
                        </td>
                        <td><%= item?.documentType || "-" %></td>
                        <td><%= item?.documentNumber || "-" %></td>
                        <td>
                            <% if(item?.status === 2) { %>
                                <span class="bet-status alert-success">Approved</span>
                            <% } else if(item?.status === 3) { %>
                                <span class="bet-status alert-end">Rejected</span>
                            <% } else { %>
                                <span class="bet-status alert-pending">Pending</span>
                            <% } %>
                        </td>
                        <td><%= formatDate(item?.createdAt) || "-" %></td>
                        <td class="text-end">
                            <div class="action-btn d-flex flex-wrap gap-2 justify-content-end">
                                <a href="/kyc/<%= item?.mechanicId %>" class="view-kyc-details" title="View Details">
                                    <i class="fa-regular fa-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7" class="text-center">No KYC records found</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
