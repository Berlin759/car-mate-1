                    <i class="fa-solid fa-car text-primary fs-5"></i>
                </div>
                <div>
                    <h5 class="mb-0"><%= body?.car?.vehicleNumber || "-" %></h5>
                    <span class="text-gray"><%= body?.car?.model || "-" %> | <%= body?.car?.vehicleManufacturerName || "-" %></span>
