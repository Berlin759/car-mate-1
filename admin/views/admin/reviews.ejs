                                <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xxl-3 col-xl-4 col-md-6 col-sm-6 col-12 custom-space user-managment">
                <div class="static-card bg-white mt-20">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="static-data">
                            <span class="sd-title fs-14 d-block">1 Star Reviews</span>
                            <span class="sd-data"><%= body?.oneStarCount || 0 %></span>
                        </div>
                        <div class="sc-img d-flex align-items-center justify-content-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" class="lucide lucide-star h-5 w-5 text-primary">
                                <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="list-filter p-3 bg-white rounded-2 bs-border d-flex align-items-center justify-content-between">
        <div class="filter-area" id="review-filter-section">
            <div class="dropdown filter-dropdown">
                <button type="button" class="filter-btn dropdown-toggle" id="rating-filter-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="fs-14 fw-md d-flex align-items-center gap-1">
                        <img src="/images/circle-plus.svg" alt="">
                        Rating
                    </span>
                    <div class="hr-line-sm d-none"></div>
                    <div class="filter-data d-none"></div>
                </button>
                <ul class="dropdown-menu filter-dropdown-menu bs-border bg-white cursor-pointer">
                    <li>
                        <a class="dropdown-item review-rating-filter" data-rating="5" data-rating-text="5 Star">5 Star</a>
                    </li>
                    <li>
                        <a class="dropdown-item review-rating-filter" data-rating="4" data-rating-text="4 Star">4 Star</a>
                    </li>
                    <li>
                        <a class="dropdown-item review-rating-filter" data-rating="3" data-rating-text="3 Star">3 Star</a>
                    </li>
                    <li>
                        <a class="dropdown-item review-rating-filter" data-rating="2" data-rating-text="2 Star">2 Star</a>
                    </li>
                    <li>
                        <a class="dropdown-item review-rating-filter" data-rating="1" data-rating-text="1 Star">1 Star</a>
                    </li>
                    <button id="clear-rating-filter" class="clear-btn fs-14 fw-normal text-center w-100 d-none">
                        Clear filters
                    </button>
                </ul>
            </div>
            <button type="button" id="reset-review-filters" class="d-none f-reset-btn fs-14 fw-md bg-transparent">
                Reset <img src="/images/f-close.svg" alt="">
            </button>
        </div>
        <div class="d-flex align-items-center flex-wrap justify-content-end gap-2">
            <div class="pagination-show d-flex align-items-center" id="pagination-div-review-list-table-data">
                Show
                <select
                    id="recordPerPage-review-list-table-data"
                    class="form-select form-select-sm w-auto"
                    onchange="changeRecordPerPage('/review-list', 'review-list-table-data')"
                >
                    <option selected="">10</option>
                    <option value="20">20</option>
                    <option value="40">40</option>
                    <option value="60">60</option>
                </select>
            </div>
            <div class="page navigation example">
                <ul class="pagination justify-content-end mb-0 gap-0"></ul>
            </div>
        </div>
    </div>
    <div class="admin-table review-list-table mt-30" id="review-list-table-data"></div>

<%- include('../footer.ejs') %>
