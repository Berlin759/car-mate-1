<%- include('../header.ejs') %>

<%
    function formatDateFull(date) {
        if (!date) return "-";

        let d = new Date(date);
        let day = ("0" + d.getDate()).slice(-2);
        let month = ("0" + (d.getMonth() + 1)).slice(-2);

        let year = d.getFullYear();
        let hours = ("0" + d.getHours()).slice(-2);
        let minutes = ("0" + d.getMinutes()).slice(-2);

        // return `${year}-${month}-${day} ${hours}:${minutes}`;
        return `${year}-${month}-${day}`;
    };

    function getStatusBadge(status) {
        const map = {
            1: { text: "Pending", class: "alert-pending" },
            2: { text: "Cancelled", class: "alert-end" },
            3: { text: "Accepted", class: "alert-accept" },
            4: { text: "En Route", class: "alert-accept" },
            5: { text: "Arrived", class: "alert-accept" },
            6: { text: "In Progress", class: "alert-accept" },
            7: { text: "Completed", class: "alert-success" },
            8: { text: "Paid", class: "alert-success" },
            9: { text: "Closed", class: "alert-success" },
        };
        return map[status] || { text: "Unknown", class: "alert-gray" };
    };

    function getPaymentMethodText(method) {
        const map = { 1: "Cash", 2: "Wallet", 3: "Card", 4: "UPI", 5: "Net Banking" };
        return map[method] || "-";
    };

    let booking = body?.booking || {};
    let statusInfo = getStatusBadge(booking.status);
%>

<div class="d-flex align-items-center justify-content-between mb-30">
    <a href="/bookings" class="btn btn-outline-secondary d-flex align-items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i> Back to List
    </a>
    <div class="d-flex align-items-center gap-2">
        <span class="bet-status <%= statusInfo.class %>"><%= statusInfo.text %></span>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="bg-white rounded-2 bs-border p-4 mb-30">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e3f2fd; width: 56px; height: 56px;">
                    <i class="fa-solid fa-calendar-check text-primary fs-5"></i>
                </div>
                <div>
                    <h5 class="mb-0"><%= booking.invoiceNo || "-" %></h5>
                    <span class="text-gray">Booking ID: <%= booking._id || "-" %></span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e8f5e9; width: 48px; height: 48px;">
                    <i class="fa-solid fa-user text-success"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Car Owner</span>
                    <span class="fw-md"><%= booking.ownerDetails?.fullName || "-" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #fff3e0; width: 48px; height: 48px;">
                    <i class="fa-solid fa-wrench text-warning"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Mechanic</span>
                    <span class="fw-md"><%= booking.mechanicDetails?.fullName || "-" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #f3e5f5; width: 48px; height: 48px;">
                    <i class="fa-solid fa-cog text-purple"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Service</span>
                    <span class="fw-md"><%= booking.serviceDetails?.fullName || "-" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e3f2fd; width: 48px; height: 48px;">
                    <i class="fa-solid fa-car text-primary"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Vehicle</span>
                    <span class="fw-md"><%= booking.carDetails?.vehicleNumber || "-" %></span>
                    <span class="text-gray fs-12 d-block"><%= booking.carDetails?.model || "" %> <%= booking.carDetails?.vehicleManufacturerName ? "- " + booking.carDetails.vehicleManufacturerName : "" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #e8f5e9; width: 48px; height: 48px;">
                    <i class="fa-solid fa-calendar text-success"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Date & Time</span>
                    <span class="fw-md"><%= formatDateFull(booking.date) || "-" %></span>
                    <span class="text-gray fs-12 d-block"><%= booking.time || "" %></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <div class="d-flex align-items-center gap-3">
                <div class="sc-img d-flex align-items-center justify-content-center rounded-circle" style="background: #fff3e0; width: 48px; height: 48px;">
                    <i class="fa-solid fa-credit-card text-warning"></i>
                </div>
                <div>
                    <span class="fs-14 text-gray d-block">Payment Method</span>
                    <span class="fw-md"><%= getPaymentMethodText(booking.paymentMethod) %></span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Service Address</h6>
    <hr>
    <div class="row">
        <div class="col-md-12 mb-3">
            <span class="fw-md"><%= booking.address || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Latitude</span>
            <span class="fw-md"><%= booking.latitude || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Longitude</span>
            <span class="fw-md"><%= booking.longitude || "-" %></span>
        </div>
    </div>
</div>

<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Price Breakdown</h6>
    <hr>
    <div class="row">
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Base Price</span>
            <span class="fw-md">&#8377; <%= booking.basePrice || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Distance Charge</span>
            <span class="fw-md">&#8377; <%= booking.distanceCharge || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Peak Hour Fee</span>
            <span class="fw-md">&#8377; <%= booking.peakHourFee || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Material Cost</span>
            <span class="fw-md">&#8377; <%= booking.materialCost || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Tax Amount</span>
            <span class="fw-md">&#8377; <%= booking.taxAmount || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Discount Amount</span>
            <span class="fw-md">&#8377; <%= booking.discountAmount || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Cancel Fee</span>
            <span class="fw-md">&#8377; <%= booking.cancelFee || 0 %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Total Amount</span>
            <span class="fw-md fs-16 text-success">&#8377; <%= booking.totalAmount || 0 %></span>
        </div>
    </div>
</div>

<% if (booking.startTime || booking.endTime) { %>
<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Service Timeline</h6>
    <hr>
    <div class="row">
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Start Time</span>
            <span class="fw-md"><%= formatDateFull(booking.startTime) || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">End Time</span>
            <span class="fw-md"><%= formatDateFull(booking.endTime) || "-" %></span>
        </div>
    </div>
</div>
<% } %>

<% if (booking.cancelReason || booking.cancelTime) { %>
<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Cancellation Details</h6>
    <hr>
    <div class="row">
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Cancel Reason</span>
            <span class="fw-md"><%= booking.cancelReason || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Cancel Time</span>
            <span class="fw-md"><%= formatDateFull(booking.cancelTime) || "-" %></span>
        </div>
    </div>
</div>
<% } %>

<% if (booking.beforePhotos && booking.beforePhotos.length > 0) { %>
<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Before Photos</h6>
    <hr>
    <div class="d-flex flex-wrap gap-3">
        <% booking.beforePhotos.forEach(function(photo) { %>
            <div>
                <img src="<%= photo %>" alt="Before Photo" class="rounded" style="max-width: 150px; max-height: 150px; object-fit: cover;">
            </div>
        <% }); %>
    </div>
</div>
<% } %>

<% if (booking.afterPhotos && booking.afterPhotos.length > 0) { %>
<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">After Photos</h6>
    <hr>
    <div class="d-flex flex-wrap gap-3">
        <% booking.afterPhotos.forEach(function(photo) { %>
            <div>
                <img src="<%= photo %>" alt="After Photo" class="rounded" style="max-width: 150px; max-height: 150px; object-fit: cover;">
            </div>
        <% }); %>
    </div>
</div>
<% } %>

<div class="bg-white rounded-2 bs-border p-4 mt-30">
    <h6 class="mb-3">Other Details</h6>
    <hr>
    <div class="row">
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Created Date</span>
            <span class="fw-md"><%= formatDateFull(booking.createdAt) || "-" %></span>
        </div>
        <div class="col-md-6 mb-3">
            <span class="text-gray fs-14 d-block">Last Updated</span>
            <span class="fw-md"><%= formatDateFull(booking.updatedAt) || "-" %></span>
        </div>
    </div>
</div>

<%- include('../footer.ejs') %>
