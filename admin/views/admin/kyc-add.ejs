<%- include('../header.ejs') %>

<div class="d-flex align-items-center justify-content-between mb-30">
    <a href="/mechanic/<%= body?.mechanic?._id %>" class="btn btn-outline-secondary d-flex align-items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i> Back to Mechanic
    </a>
    <h5 class="mb-0">Submit KYC for <%= body?.mechanic?.fullName || "Mechanic" %></h5>
</div>

<div class="row">
    <div class="col-lg-8">
        <form id="kyc-submit-form" enctype="multipart/form-data">
            <input type="hidden" id="mechanic-id" value="<%= body?.mechanic?._id %>">

            <div class="bg-white rounded-2 bs-border p-4 mb-30">
                <h6 class="mb-3">Identity Documents</h6>
                <hr>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="aadhaarFront" class="form-label text-dark">Aadhaar Front <span class="text-danger">*</span></label>
                        <input class="form-control" type="file" id="aadhaarFront" name="aadhaarFront" accept="image/*">
                        <div id="aadhaarFront-preview" class="mt-2"></div>
                    </div>
                    <div class="col-md-6">
                        <label for="aadhaarBack" class="form-label text-dark">Aadhaar Back <span class="text-danger">*</span></label>
                        <input class="form-control" type="file" id="aadhaarBack" name="aadhaarBack" accept="image/*">
                        <div id="aadhaarBack-preview" class="mt-2"></div>
                    </div>
                    <div class="col-md-6">
                        <label for="panCard" class="form-label text-dark">PAN Card</label>
                        <input class="form-control" type="file" id="panCard" name="panCard" accept="image/*">
                        <div id="panCard-preview" class="mt-2"></div>
                    </div>
                    <div class="col-md-6">
                        <label for="drivingLicense" class="form-label text-dark">Driving License</label>
                        <input class="form-control" type="file" id="drivingLicense" name="drivingLicense" accept="image/*">
                        <div id="drivingLicense-preview" class="mt-2"></div>
                    </div>
                    <div class="col-md-6">
                        <label for="selfie" class="form-label text-dark">Selfie</label>
                        <input class="form-control" type="file" id="selfie" name="selfie" accept="image/*">
                        <div id="selfie-preview" class="mt-2"></div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2 bs-border p-4 mb-30">
                <h6 class="mb-3">Bank Details</h6>
                <hr>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="bankAccountHolderName" class="form-label text-dark">Account Holder Name</label>
                        <input class="form-control" type="text" id="bankAccountHolderName" name="bankAccountHolderName" placeholder="Enter account holder name">
                    </div>
                    <div class="col-md-6">
                        <label for="bankName" class="form-label text-dark">Bank Name</label>
                        <input class="form-control" type="text" id="bankName" name="bankName" placeholder="Enter bank name">
                    </div>
                    <div class="col-md-6">
                        <label for="bankAccountNumber" class="form-label text-dark">Account Number</label>
                        <input class="form-control" type="text" id="bankAccountNumber" name="bankAccountNumber" placeholder="Enter account number">
                    </div>
                    <div class="col-md-6">
                        <label for="bankIfscCode" class="form-label text-dark">IFSC Code</label>
                        <input class="form-control" type="text" id="bankIfscCode" name="bankIfscCode" placeholder="Enter IFSC code">
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a href="/mechanic/<%= body?.mechanic?._id %>" class="btn btn btn-primary btn-transparent">Cancel</a>
                <button type="submit" class="btn btn-primary" id="submit-kyc-btn">Submit KYC</button>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="bg-white rounded-2 bs-border p-4">
            <h6 class="mb-3">Mechanic Info</h6>
            <hr>
            <div class="d-flex flex-column gap-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="user-avatar-sm text-white">
                        <% if(body?.mechanic?.profileImage) { %>
                            <img src="<%= body.mechanic.profileImage %>" alt="Profile" class="rounded-circle" width="40" height="40">
                        <% } else { %>
                            <img src="<%= process.env.SERVER_URL + '/images/profile.png' %>" alt="Profile" class="rounded-circle" height="40">
                        <% } %>
                    </div>
                    <div>
                        <div class="fw-md"><%= body?.mechanic?.fullName || "-" %></div>
                        <div class="text-gray fs-12"><%= body?.mechanic?.email || "" %></div>
                    </div>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-gray">Phone</span>
                    <span class="fw-md">
                        <% if(body?.mechanic?.phoneNumber) { %>
                            <%= body?.mechanic?.countryCode || "+91" %> <%= body?.mechanic?.phoneNumber %>
                        <% } else { %>
                            -
                        <% } %>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../footer.ejs') %>
