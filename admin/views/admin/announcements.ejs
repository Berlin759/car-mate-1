<%- include('../header.ejs') %>
    <div class="list-filter p-3 bg-white rounded-2 bs-border d-flex align-items-center justify-content-between">
        <div class="filter-area d-flex align-items-center gap-2 flex-wrap" id="announcement-filter-section">
            <!-- No filters for announcements -->
        </div>
        <div class="d-flex align-items-center flex-wrap justify-content-end gap-2">
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addAnnouncementModal" id="add_new_announcement_btn">
                <i class="fa-solid fa-plus me-1"></i> Add Announcement
            </button>
            <div class="pagination-show d-flex align-items-center" id="pagination-div-announcement-list-table-data">
                Show
                <select id="recordPerPage-announcement-list-table-data" class="form-select form-select-sm w-auto" onchange="changeRecordPerPage('/announcement-list', 'announcement-list-table-data')">
                    <option selected="">10</option>
                    <option value="20">20</option>
                    <option value="40">40</option>
                </select>
            </div>
            <div class="page navigation example">
                <ul class="pagination justify-content-end mb-0 gap-0"></ul>
            </div>
        </div>
    </div>
    <div class="admin-table announcement-list-table mt-30" id="announcement-list-table-data"></div>

    <!-- Add Announcement Modal -->
    <div class="modal custom-popup fade" id="addAnnouncementModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header justify-content-center mt-3">
                    <h5 class="modal-title">Add Announcement</h5>
                </div>
                <div class="modal-body px-4 pb-4">
                    <div class="row g-3">
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Title <span class="text-danger">*</span></label>
                            <input class="form-control" type="text" id="announcement_title" placeholder="Enter title" pattern="[a-zA-Z\s]+" maxlength="50" required>
                            <small class="text-muted"><span id="announcement_title_counter">0/50</span> characters</small>
                        </div>
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Description <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="announcement_description" rows="3" placeholder="Enter description" maxlength="250" required></textarea>
                            <small class="text-muted"><span id="announcement_desc_counter">0/200</span> characters</small>
                        </div>
                        <div class="col-lg-12">
                            <label class="form-label text-dark">Target Audience <span class="text-danger">*</span></label>
                            <select class="form-select" id="announcement_target" required>
                                <option value="all">All</option>
                                <option value="owner">Car Owners</option>
                                <option value="mechanic">Mechanics</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 d-flex justify-content-end">
                    <button type="button" class="btn btn-primary btn-transparent" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="save_announcement">Save Announcement</button>
                </div>
            </div>
        </div>
    </div>
<%- include('../footer.ejs') %>
