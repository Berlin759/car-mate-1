<%- include("../header.ejs") %>

    <div class="row">
        <div class="col-md-6 col-12">
            <h5 class="fs-20 mb-20 fw-md stas-heading text-uppercase">General</h5>
            <div class="custom-card setting-card">
                <div class="genral-setting">
                    <div class="g-items d-flex">
                        <label>Login URL Token</label>
                        <div class="form-group">
                            <input id="login_secret_token" type="text" class="form-control" value="<%= body?.secret || "Scottiger" %>">
                        </div>
                    </div>
                    <div class="g-items d-flex">
                        <label>Maintenance Mode</label>
                        <div class="form-group">
                            <label class="switch">
                                <input id="maintenance" class="form-check-input" type="checkbox" <%= body?.maintenance == "2" ? "checked" : "" %> value="<%= body?.maintenance %>">
                                <span class="slider"> <span class="t-line"></span></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="page-btn mt-20">
                <button id="updateSettings" class="btn btn-primary">
                    Save Changes
                </button>
            </div>
        </div>
        <div class="col-md-6 col-12">
            <h5 class="fs-20 mb-20 fw-md stas-heading text-uppercase">Change Password</h5>
            <div class="custom-card setting-card pb-5">
                <div class="card-title">
                    <div class="custom-form">
                        <div class="form-group both-icon position-relative">
                            <svg class="ico-left" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
