                                        stroke="#7E8B95" stroke-width="1.5" stroke-linecap="round"
                                        stroke-linejoin="round"></path>
                                    <path d="M8.25 12C8.25 12.1989 8.32902 12.3897 8.46967 12.5303C8.61032 12.671 8.80109 12.75 9 12.75C9.19891 12.75 9.38968 12.671 9.53033 12.5303C9.67098 12.3897 9.75 12.1989 9.75 12C9.75 11.8011 9.67098 11.6103 9.53033 11.4697C9.38968 11.329 9.19891 11.25 9 11.25C8.80109 11.25 8.61032 11.329 8.46967 11.4697C8.32902 11.6103 8.25 11.8011 8.25 12Z"
                                        stroke="#7E8B95" stroke-width="1.5" stroke-linecap="round"
                                        stroke-linejoin="round"></path>
                                    <path d="M6 8.25V5.25C6 4.45435 6.31607 3.69129 6.87868 3.12868C7.44129 2.56607 8.20435 2.25 9 2.25C9.79565 2.25 10.5587 2.56607 11.1213 3.12868C11.6839 3.69129 12 4.45435 12 5.25V8.25"
                                        stroke="#7E8B95" stroke-width="1.5" stroke-linecap="round"
                                        stroke-linejoin="round"></path>
                                </g>
                                <defs>
                                    <clipPath id="clip0_417_58442">
                                        <rect width="18" height="18" fill="white"></rect>
                                    </clipPath>
                                </defs>
                            </svg>
                            <input type="password" id="new_password" placeholder="New Password" class="form-control">
                            <i class="far fa-eye-slash fa-fw ico-right cursor-pointer" id="ey3"></i>
                        </div>
                    </div>
                    <div class="c-notes mt-20">
                        <h3>Password Requirements:</h3>
                        <ul class="mt-20">
                            <li>Your new password must be different from your current password to ensure account
                                security.</li>
                            <li>Your new password must be at least 6 characters long.</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="page-btn mt-20">
                <button id="updatePassword" class="btn btn-primary" disabled>
                    Change Password
                </button>
            </div>
        </div>
    </div>

<%- include("../footer.ejs") %>