                            <input type="password" id="current_password" class="form-control" placeholder="Current Password">
                            <i class="far fa-eye-slash fa-fw ico-right cursor-pointer" id="ey2"></i>
                        </div>
                        <div class="form-group mt-20 both-icon position-relative">
                            <svg class="ico-left" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
